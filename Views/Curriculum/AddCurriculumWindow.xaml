<Window x:Class="UniversityScheduler.Views.AddCurriculumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Curriculum Entry" Height="550" Width="600" WindowStartupLocation="CenterScreen" 
        Icon="/UNIGAMIicon128.ico">
    <Border Padding="20" Background="#F7F9F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Manage Curriculum Card" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Program:"/>
                        <ComboBox x:Name="ProgramCombo" Height="30" IsEditable="True"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Year Level:"/>
                        <ComboBox x:Name="YearCombo" Height="30" SelectedIndex="0">
                            <ComboBoxItem Content="1st Year" Tag="1"/>
                            <ComboBoxItem Content="2nd Year" Tag="2"/>
                            <ComboBoxItem Content="3rd Year" Tag="3"/>
                            <ComboBoxItem Content="4th Year" Tag="4"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Semester:"/>
                        <ComboBox x:Name="SemesterCombo" Height="30" SelectedIndex="0">
                            <ComboBoxItem Content="1st Semester" Tag="1"/>
                            <ComboBoxItem Content="2nd Semester" Tag="2"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Add Course to Card:"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    
                    <ComboBox x:Name="CourseCombo" Height="30" DisplayMemberPath="FullDisplay" 
                              SelectedValuePath="Id" IsEditable="True" StaysOpenOnEdit="True"
                              IsTextSearchEnabled="True" TextSearch.TextPath="FullDisplay"/>
                    <Button Grid.Column="1" Content="Add" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="AddCourse_Click"/>
                </Grid>
            </StackPanel>

            <DataGrid x:Name="SelectedCoursesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Subject" Binding="{Binding Code}" Width="80" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Units" Binding="{Binding Units}" Width="50"/>
                    <DataGridTextColumn Header="Lec" Binding="{Binding LectureHours}" Width="40"/>
                    <DataGridTextColumn Header="Lab" Binding="{Binding LabHours}" Width="40"/>
                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Foreground="#E74C3C" Background="Transparent" Padding="1" BorderBrush="Transparent" BorderThickness="0" Cursor="Hand" Click="RemoveCourse_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="2" Content="Save Card" Style="{StaticResource PrimaryButton}" Height="40" Click="Save_Click"/>
        </Grid>
    </Border>
</Window>