<Window x:Class="UniversityScheduler.Views.ClassExportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class Export Settings" Height="300" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F9F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Class Export Formatting" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

            <TextBlock Text="University Name (A2):" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="UniNameTxt" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Department Name (A3):" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="DeptNameTxt" Height="30" Padding="5" Margin="0,0,0,15"/>
        </StackPanel>

        <Button Grid.Row="1" Content="Save Settings" Height="40" Margin="0,15,0,0" Style="{StaticResource PrimaryButton}" FontWeight="Bold" Click="Save_Click"/>
    </Grid>
</Window>