<Window x:Class="UniversityScheduler.Views.RoomExportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Export Settings" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F9F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Room Export Formatting" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <TextBlock Text="University Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="UniNameTxt" Height="30" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Department Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="DeptNameTxt" Height="30" Padding="5" Margin="0,0,0,15"/>

                <TextBlock Text="Room Type Formatting (Prefixes):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock Text="E.g., If room type is 'Classroom', output 'Room 301'" FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>
                
                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Padding="10">
                    <ItemsControl x:Name="TypePrefixesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding RoomType}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#34495E"/>
                                    <TextBox Grid.Column="1" Text="{Binding Prefix}" Height="28" Padding="5"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1" Content="Save Settings" Height="40" Margin="0,15,0,0" Style="{StaticResource PrimaryButton}" FontWeight="Bold" Click="Save_Click"/>
    </Grid>
</Window>