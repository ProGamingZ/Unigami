<Window x:Class="UniversityScheduler.Views.AddInstructorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Add New Instructor" Height="800" Width="660" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip" Icon="/UNIGAMIicon128.ico">
    
    <Grid Background="#F7F9F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Info -->
            <RowDefinition Height="*"/>    <!-- Semester Tabs -->
            <RowDefinition Height="Auto"/> <!-- Save Button -->
        </Grid.RowDefinitions>

        <!-- GLOBAL INSTRUCTOR INFO -->
        <Border Grid.Row="0" Padding="20,20,20,5">
            <StackPanel>
                <TextBlock Text="Global Instructor Details" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <!-- NAME GRID -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/> <ColumnDefinition Width="*"/>  <ColumnDefinition Width="*"/>  <ColumnDefinition Width="*"/>  <ColumnDefinition Width="65"/> <ColumnDefinition Width="65"/> 
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Title:"/>
                        <ComboBox x:Name="TitleCombo" Height="30" IsEditable="True">
                            <ComboBoxItem Content="Mr."/> <ComboBoxItem Content="Ms."/> <ComboBoxItem Content="Mrs."/> <ComboBoxItem Content="Dr."/> <ComboBoxItem Content="Engr."/> <ComboBoxItem Content="Atty."/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,5,0">
                        <TextBlock Text="First Name:"/>
                        <TextBox x:Name="FirstNameTxt" Height="30" TextChanged="NameTxt_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,5,0">
                        <TextBlock Text="Middle Name:"/>
                        <TextBox x:Name="MiddleNameTxt" Height="30" TextChanged="NameTxt_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,5,0">
                        <TextBlock Text="Surname:"/>
                        <TextBox x:Name="SurnameTxt" Height="30" TextChanged="NameTxt_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="0,0,10,0">
                        <TextBlock Text="Suffix:"/>
                        <TextBox x:Name="SuffixTxt" Height="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="5">
                        <TextBlock Text="Initials:"/>
                        <TextBox x:Name="InitialsTxt" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- OFFICIAL TEMPLATE INFO GRID -->
                <TextBlock Text="Official Template Info:" FontWeight="Bold" Margin="0,5,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Home Address:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="AddressTxt" Height="25" Margin="0,2,0,5"/>
                        <TextBlock Text="Baccalaureate Degree:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="BaccTxt" Height="25" Margin="0,2,0,5"/>
                        <TextBlock Text="Master's Degree:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="MasterTxt" Height="25"/>
                        <TextBlock Text="Doctoral Degree:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="DoctorTxt" Height="25" Margin="0,2,0,5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Teaching Exp (Public Years):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="ExpPublicTxt" Height="25" Text="0" Margin="0,2,0,5"/>
                        <TextBlock Text="Teaching Exp (Private Years):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="ExpPrivateTxt" Height="25" Text="0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- SEMESTER TABS -->
        <TabControl x:Name="SemesterTabs" Grid.Row="1" Margin="10,0,10,0">
            
            <!-- ==================== SEMESTER 1 TAB ==================== -->
            <TabItem Header="Semester 1 Settings" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> 
                                <ColumnDefinition Width="*"/> 
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Assigned Room (Sem 1):" Margin="0,0,0,2"/>
                                <ComboBox x:Name="AssignedRoomComboSem1" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Preferred Year Levels:" Margin="0,0,0,2"/>
                                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Padding="5">
                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="CbYear1Sem1" Content="1st Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear2Sem1" Content="2nd Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear3Sem1" Content="3rd Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear4Sem1" Content="4th Year" Margin="2"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Employment Status (Sem 1):"/>
                                <ComboBox x:Name="StatusComboSem1" Height="30" SelectedIndex="0">
                                    <ComboBoxItem Content="Full-time"/> <ComboBoxItem Content="Part-time"/> <ComboBoxItem Content="Visiting"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Max Units (0-24):"/>
                                <TextBox x:Name="UnitsTxtSem1" Height="30" Text="24"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Select Programs (Sem 1):" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Height="80">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ProgramCheckListSem1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="10,5" Foreground="#2C3E50" FontSize="13"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Sem 1: Select Preferred Days" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="All" Margin="10,0,5,0" Padding="5,0" Height="20" Click="SelectAllDays_Click"/>
                            <Button Content="None" Padding="5,0" Height="20" Click="SelectNoDays_Click"/>
                        </StackPanel>
                        <WrapPanel x:Name="DayCheckboxesSem1" Margin="0,0,0,10">
                            <CheckBox Content="Mon" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Tue" Margin="0,0,15,0" IsChecked="True"/>
                            <CheckBox Content="Wed" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Thu" Margin="0,0,15,0" IsChecked="True"/>
                            <CheckBox Content="Fri" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Sat" Margin="0,0,15,0" IsChecked="True"/>
                        </WrapPanel>

                        <TextBlock Text="Sem 1: Select Time Range" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="30"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> 
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ComboBox x:Name="StartHourComboSem1" Width="50" SelectedIndex="6">
                                    <System:String>1</System:String> <System:String>2</System:String> <System:String>3</System:String> <System:String>4</System:String> <System:String>5</System:String> <System:String>6</System:String> <System:String>7</System:String> <System:String>8</System:String> <System:String>9</System:String> <System:String>10</System:String> <System:String>11</System:String> <System:String>12</System:String>
                                </ComboBox>
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                <ComboBox x:Name="StartMinComboSem1" Width="50" SelectedIndex="0">
                                    <System:String>00</System:String> <System:String>15</System:String> <System:String>30</System:String> <System:String>45</System:String>
                                </ComboBox>
                                <ComboBox x:Name="StartAmPmComboSem1" Width="55" SelectedIndex="0" Margin="5,0,0,0">
                                    <System:String>AM</System:String> <System:String>PM</System:String>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="to" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Gray"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ComboBox x:Name="EndHourComboSem1" Width="50" SelectedIndex="4">
                                    <System:String>1</System:String> <System:String>2</System:String> <System:String>3</System:String> <System:String>4</System:String> <System:String>5</System:String> <System:String>6</System:String> <System:String>7</System:String> <System:String>8</System:String> <System:String>9</System:String> <System:String>10</System:String> <System:String>11</System:String> <System:String>12</System:String>
                                </ComboBox>
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                <ComboBox x:Name="EndMinComboSem1" Width="50" SelectedIndex="0">
                                    <System:String>00</System:String> <System:String>15</System:String> <System:String>30</System:String> <System:String>45</System:String>
                                </ComboBox>
                                <ComboBox x:Name="EndAmPmComboSem1" Width="55" SelectedIndex="1" Margin="5,0,0,0">
                                    <System:String>AM</System:String> <System:String>PM</System:String>
                                </ComboBox>
                            </StackPanel>
                            <Button Grid.Column="4" Content="Add Block" Width="80" Style="{StaticResource SecondaryButton}" Click="AddBlock_Click"/>
                        </Grid>

                        <ListBox x:Name="PreferencesListSem1" Height="80" Margin="0,0,0,15" BorderBrush="Gray" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayString}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Remove" Background="#E74C3C" Foreground="White" FontSize="10" Padding="5,2" Margin="10,0,0,0" Click="RemoveBlock_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Sem 1: Assign Specific Courses" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PreferredCourseComboSem1" Height="30" DisplayMemberPath="FullDisplay" SelectedValuePath="Code" IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="True" TextSearch.TextPath="FullDisplay" DropDownOpened="PreferredCourseCombo_DropDownOpened"/>
                            <Button Grid.Column="1" Content="Add Course" Width="80" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="AddPreferredCourse_Click"/>
                        </Grid>
                        <ListBox x:Name="PreferredCoursesListSem1" Height="80" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FullDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Remove" Background="#E74C3C" Foreground="White" FontSize="10" Padding="5,2" Margin="10,0,0,0" Click="RemovePreferredCourse_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== SEMESTER 2 TAB ==================== -->
            <TabItem Header="Semester 2 Settings" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> 
                                <ColumnDefinition Width="*"/> 
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Assigned Room (Sem 2):" Margin="0,0,0,2"/>
                                <ComboBox x:Name="AssignedRoomComboSem2" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id" IsEditable="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Preferred Year Levels:" Margin="0,0,0,2"/>
                                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Padding="5">
                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="CbYear1Sem2" Content="1st Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear2Sem2" Content="2nd Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear3Sem2" Content="3rd Year" Margin="2"/>
                                        <CheckBox x:Name="CbYear4Sem2" Content="4th Year" Margin="2"/>
                                    </UniformGrid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Employment Status (Sem 2):"/>
                                <ComboBox x:Name="StatusComboSem2" Height="30" SelectedIndex="0">
                                    <ComboBoxItem Content="Full-time"/> <ComboBoxItem Content="Part-time"/> <ComboBoxItem Content="Visiting"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Max Units (0-24):"/>
                                <TextBox x:Name="UnitsTxtSem2" Height="30" Text="24"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Select Programs (Sem 2):" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Height="80">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ProgramCheckListSem2">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="10,5" Foreground="#2C3E50" FontSize="13"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Sem 2: Select Preferred Days" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="All" Margin="10,0,5,0" Padding="5,0" Height="20" Click="SelectAllDays_Click"/>
                            <Button Content="None" Padding="5,0" Height="20" Click="SelectNoDays_Click"/>
                        </StackPanel>
                        <WrapPanel x:Name="DayCheckboxesSem2" Margin="0,0,0,10">
                            <CheckBox Content="Mon" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Tue" Margin="0,0,15,0" IsChecked="True"/>
                            <CheckBox Content="Wed" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Thu" Margin="0,0,15,0" IsChecked="True"/>
                            <CheckBox Content="Fri" Margin="0,0,15,0" IsChecked="True"/> <CheckBox Content="Sat" Margin="0,0,15,0" IsChecked="True"/>
                        </WrapPanel>

                        <TextBlock Text="Sem 2: Select Time Range" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="30"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/> 
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ComboBox x:Name="StartHourComboSem2" Width="50" SelectedIndex="6">
                                    <System:String>1</System:String> <System:String>2</System:String> <System:String>3</System:String> <System:String>4</System:String> <System:String>5</System:String> <System:String>6</System:String> <System:String>7</System:String> <System:String>8</System:String> <System:String>9</System:String> <System:String>10</System:String> <System:String>11</System:String> <System:String>12</System:String>
                                </ComboBox>
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                <ComboBox x:Name="StartMinComboSem2" Width="50" SelectedIndex="0">
                                    <System:String>00</System:String> <System:String>15</System:String> <System:String>30</System:String> <System:String>45</System:String>
                                </ComboBox>
                                <ComboBox x:Name="StartAmPmComboSem2" Width="55" SelectedIndex="0" Margin="5,0,0,0">
                                    <System:String>AM</System:String> <System:String>PM</System:String>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="to" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Gray"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ComboBox x:Name="EndHourComboSem2" Width="50" SelectedIndex="4">
                                    <System:String>1</System:String> <System:String>2</System:String> <System:String>3</System:String> <System:String>4</System:String> <System:String>5</System:String> <System:String>6</System:String> <System:String>7</System:String> <System:String>8</System:String> <System:String>9</System:String> <System:String>10</System:String> <System:String>11</System:String> <System:String>12</System:String>
                                </ComboBox>
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                <ComboBox x:Name="EndMinComboSem2" Width="50" SelectedIndex="0">
                                    <System:String>00</System:String> <System:String>15</System:String> <System:String>30</System:String> <System:String>45</System:String>
                                </ComboBox>
                                <ComboBox x:Name="EndAmPmComboSem2" Width="55" SelectedIndex="1" Margin="5,0,0,0">
                                    <System:String>AM</System:String> <System:String>PM</System:String>
                                </ComboBox>
                            </StackPanel>
                            <Button Grid.Column="4" Content="Add Block" Width="80" Style="{StaticResource SecondaryButton}" Click="AddBlock_Click"/>
                        </Grid>

                        <ListBox x:Name="PreferencesListSem2" Height="80" Margin="0,0,0,15" BorderBrush="Gray" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayString}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Remove" Background="#E74C3C" Foreground="White" FontSize="10" Padding="5,2" Margin="10,0,0,0" Click="RemoveBlock_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Sem 2: Assign Specific Courses" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PreferredCourseComboSem2" Height="30" DisplayMemberPath="FullDisplay" SelectedValuePath="Code" IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="True" TextSearch.TextPath="FullDisplay" DropDownOpened="PreferredCourseCombo_DropDownOpened"/>
                            <Button Grid.Column="1" Content="Add Course" Width="80" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="AddPreferredCourse_Click"/>
                        </Grid>
                        <ListBox x:Name="PreferredCoursesListSem2" Height="80" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/> <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FullDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <Button Grid.Column="1" Content="Remove" Background="#E74C3C" Foreground="White" FontSize="10" Padding="5,2" Margin="10,0,0,0" Click="RemovePreferredCourse_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- SAVE BUTTON -->
        <Border Grid.Row="2" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0" Padding="10,10,10,0">
            <Button Content="Save Instructor (Both Semesters)" Height="40" Style="{StaticResource PrimaryButton}" FontWeight="Bold" Click="Save_Click"/>
        </Border>
    </Grid>
</Window>