<Window x:Class="UniversityScheduler.Views.ExportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel Export Settings" Height="600" Width="550"
        WindowStartupLocation="CenterOwner" Background="#F7F9F9" ResizeMode="NoResize">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="White" BorderBrush="#BDC3C7">
            <!-- TAB 1: SIGNATORIES -->
            <TabItem Header="General &amp; Signatories">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Document Info &amp; ISO Codes" FontWeight="Bold" Margin="0,5,0,5"/>
                        <TextBlock Text="School Year (e.g., 2026-2027):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtSchoolYear" Margin="0,0,0,10"/>
                        <TextBlock Text="Semester (e.g., First Semester):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtSemester" Margin="0,0,0,10"/>
                        <TextBlock Text="Academic Level:" FontSize="11" Foreground="Gray"/>
                        <ComboBox x:Name="ComboAcademicLevel" Margin="0,0,0,10">
                            <ComboBoxItem Content="Undergraduate"/>
                            <ComboBoxItem Content="Graduate"/>
                        </ComboBox>
                        <TextBlock Text="DPTL Code (Form Control Code):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtDPTLCode" Margin="0,0,0,20"/>
                        <TextBlock Text="Department Name (e.g., CCIS):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtDepartmentName" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Signatories" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="Dean 1 Name:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtDean1" Margin="0,0,0,10"/>
                        <TextBlock Text="Dean 2 Name:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtDean2" Margin="0,0,0,10"/>
                        <TextBlock Text="Dean 3 Name:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtDean3" Margin="0,0,0,10"/>
                        <TextBlock Text="VP for Academic Affairs:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtVPAcad" Margin="0,0,0,10"/>
                        <TextBlock Text="VP for Research/Extension:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtVPRes" Margin="0,0,0,10"/>
                        <TextBlock Text="VP for Administration:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtVPAdmin" Margin="0,0,0,10"/>
                        <TextBlock Text="University President:" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtPresident" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: DATES -->
            <TabItem Header="Dates">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel x:Name="DatesPanel">
                        <TextBlock Text="Check 'Use Today' to automatically inject the current date during export." TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,15"/>
                        <!-- Date rows will be generated in C# for cleaner code -->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: FORMULAS -->
            <TabItem Header="Math &amp; Formulas">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Row Multipliers" FontWeight="Bold" Margin="0,5,0,5"/>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Weeks in a Semester (For Contact Hrs):" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtWeeks" Grid.Column="1" TextAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Excel Summary Formulas (Injected into cells)" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="Edit these if you change the cell layout in your template." FontSize="11" Foreground="Gray" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Total Lecture Hours Formula (V49):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtFormLec" Margin="0,0,0,10"/>
                        <TextBlock Text="Total Lab Hours Formula (V50):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtFormLab" Margin="0,0,0,10"/>
                        <TextBlock Text="Total Student Contact Formula (AX48):" FontSize="11" Foreground="Gray"/>
                        <TextBox x:Name="TxtFormContact" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🧪 Generate Mock Preview" Background="#27AE60" Foreground="White" Padding="10,5" Click="GenerateMock_Click"/>
            <Button Grid.Column="2" Content="Save Settings" Width="120" Padding="10,5" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>