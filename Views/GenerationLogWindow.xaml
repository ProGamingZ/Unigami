<Window x:Class="UniversityScheduler.Views.GenerationLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scheduler Output Log" Height="900" Width="700" 
        Icon="pack://application:,,,/UNIGAMIicon128.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="LogBox" 
                 Grid.Row="0"
                 Background="#1E1E1E" 
                 Foreground="#00FF00" 
                 FontFamily="Consolas" 
                 FontSize="14" 
                 IsReadOnly="True" 
                 VerticalScrollBarVisibility="Auto" 
                 HorizontalScrollBarVisibility="Auto"
                 Padding="10"
                 TextWrapping="Wrap"/>

        <Button Grid.Row="1" Content="Close" Height="40" Click="Close_Click" Margin="5"/>
    </Grid>

</Window>