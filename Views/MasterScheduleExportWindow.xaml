<Window x:Class="UniversityScheduler.Views.MasterScheduleExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Master Schedule" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7F9F9">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Master Schedule Export" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

            <TextBlock Text="School Year" FontSize="11" Foreground="Gray"/>
            <TextBox x:Name="SyTxt" Text="SY: 2025-2026" Height="25" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Date (Leave blank for current date)" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            <TextBox x:Name="DateTxt" Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <TextBlock Text="Department Name" FontSize="11" Foreground="Gray"/>
            <TextBox x:Name="DeptNameTxt" Text="COLLEGE OF COMPUTING AND INFORMATION SCIENCES" Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <TextBlock Text="Department Acronym" FontSize="11" Foreground="Gray"/>
            <TextBox x:Name="DeptAcronymTxt" Text="CCIS" Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Secretary Name" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="SecNameTxt" Height="25" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Secretary Position" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="SecPosTxt" Text="SECRETARY" Height="25" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dean Name" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="DeanNameTxt" Height="25" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Dean Position" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="DeanPosTxt" Text="DEAN" Height="25" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Button Content="Save Settings" Click="SaveSettings_Click"/>
        </StackPanel>
    </Grid>
</Window>