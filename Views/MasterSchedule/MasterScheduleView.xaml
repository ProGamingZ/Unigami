<UserControl x:Class="UniversityScheduler.Views.MasterScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource TextLightBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                
                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Semester" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="SemSelector" Width="70" Height="28" SelectedIndex="0" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="1st Sem" Tag="1"/>
                        <ComboBoxItem Content="2nd Sem" Tag="2"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Day" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="DaySelector" Width="85" Height="28" SelectedIndex="0" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="Monday" Tag="Mon"/>
                        <ComboBoxItem Content="Tuesday" Tag="Tue"/>
                        <ComboBoxItem Content="Wednesday" Tag="Wed"/>
                        <ComboBoxItem Content="Thursday" Tag="Thu"/>
                        <ComboBoxItem Content="Friday" Tag="Fri"/>
                        <ComboBoxItem Content="Saturday" Tag="Sat"/>
                        <ComboBoxItem Content="Sunday" Tag="Sun"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Program" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ProgramSelector" Width="90" Height="28" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True"/>
                        </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Year" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="YearSelector" Width="70" Height="28" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="1st" Tag="1"/>
                        <ComboBoxItem Content="2nd" Tag="2"/>
                        <ComboBoxItem Content="3rd" Tag="3"/>
                        <ComboBoxItem Content="4th" Tag="4"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Class Section" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ClassSelector" Width="100" Height="28" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="All Classes" Tag="All" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Instructor" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="InstructorSelector" Width="160" Height="28" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="All Instructors" Tag="All" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,10,5">
                    <TextBlock Text="Course" FontSize="10" Foreground="{StaticResource TextDarkBrush}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CourseSelector" Width="110" Height="28" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="All Courses" Tag="All" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>


                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,5">
                    <Button Content="⚙ Constraints" 
                            Background="{StaticResource SidebarBrush}" Style="{StaticResource MasterSchedButtonStyle}"                           
                            Click="Settings_Click"/>
                    <Button Content="Generate" 
                            Style="{StaticResource MasterSchedButtonStyle}"
                            Click="GenerateSchedule_Click"/>
                    <Button Content="Assign" 
                            Style="{StaticResource MasterSchedButtonStyle}"
                            Click="AssignInstructors_Click"/>

                    <Button Content="Save Schedule" 
                            Style="{StaticResource MasterSchedButtonStyle}"
                            Click="SaveSchedule_Click"/>

                    <Button Content="Import" 
                            Style="{StaticResource MasterSchedButtonStyle}"
                            Click="ImportSchedule_Click"/>
                            
                    <Button Content="Wipe Data" 
                            Style="{StaticResource MasterSchedButtonStyle}"
                            Click="WipeData_Click"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="1" Background="{StaticResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/> 
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>   
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource TextLightBrush}" BorderThickness="0,0,1,1">
                <TextBlock Text="TIME" Foreground="{StaticResource BackgroundBrush}" FontWeight="Bold" FontSize="12" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer x:Name="HeaderScroll" Grid.Row="0" Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <Grid x:Name="RoomHeaderGrid"/>
            </ScrollViewer>

            <ScrollViewer x:Name="TimeScroll" Grid.Row="1" Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                <Grid x:Name="TimeHeaderGrid"/>
            </ScrollViewer>

            <ScrollViewer x:Name="MainScroll" Grid.Row="1" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="MainScroll_ScrollChanged">
                <Grid x:Name="ScheduleGrid"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>