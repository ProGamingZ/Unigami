<Window x:Class="UniversityScheduler.Views.SchedulerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Scheduler Configuration" Height="650" Width="550" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5" Icon="/UNIGAMIicon128.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Generation Settings" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#BDC3C7">
            
            <TabItem Header="Constraints" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        
                        <GroupBox Header="Operating Hours" Margin="0,0,0,15" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Day Start (AM):"/>
                                    <ComboBox x:Name="StartHourCombo" SelectedIndex="0" Margin="0,5,0,0">
                                        <ComboBoxItem Content="6:00 AM" Tag="6"/>
                                        <ComboBoxItem Content="7:00 AM" Tag="7"/>
                                        <ComboBoxItem Content="8:00 AM" Tag="8"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" Margin="10,15,10,0"/>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Day End (PM):"/>
                                    <ComboBox x:Name="EndHourCombo" SelectedIndex="2" Margin="0,5,0,0">
                                        <ComboBoxItem Content="7:00 PM" Tag="19"/>
                                        <ComboBoxItem Content="8:00 PM" Tag="20"/>
                                        <ComboBoxItem Content="9:00 PM" Tag="21"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Advanced Course Rules" Margin="0,0,0,15" Padding="5">
                            <TabControl Height="220" BorderThickness="0">
                                
                                <TabItem Header="📅 Day Limits">
                                    <Grid Margin="5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="Force courses to specific days (e.g. NSTP -> Sat)" Foreground="Gray" FontSize="13" Margin="0,0,0,5"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                            <ComboBox x:Name="DayRuleInput" Width="100" Height="25" 
                                                    IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                                                    KeyUp="CourseInput_KeyUp"
                                                    ToolTip="Type to search Course Code (e.g. CS101)"/>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                <CheckBox x:Name="DayCbMon" Content="M" Margin="0,0,5,0"/>
                                                <CheckBox x:Name="DayCbTue" Content="T" Margin="0,0,5,0"/>
                                                <CheckBox x:Name="DayCbWed" Content="W" Margin="0,0,5,0"/>
                                                <CheckBox x:Name="DayCbThu" Content="Th" Margin="0,0,5,0"/>
                                                <CheckBox x:Name="DayCbFri" Content="F" Margin="0,0,5,0"/>
                                                <CheckBox x:Name="DayCbSat" Content="S" Margin="0,0,5,0"/>
                                            </StackPanel>
                                            <Button Content="Add" Width="50" Click="AddDayRule_Click"/>
                                        </StackPanel>

                                        <ListBox x:Name="DayRulesList" Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="1" Padding="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="transparent" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="12" Padding="8,3" Margin="0,0,5,5">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock Text="{Binding DisplayString}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                                            <Button Content="X" DockPanel.Dock="Right" Padding="1" Width="16" Height="16" Cursor="Hand"
                                                                    Background="Transparent" Foreground="#E74C3C" FontWeight="Bold" BorderThickness="0" 
                                                                    Click="RemoveDayRule_Click" Tag="{Binding}"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="⏰ Time Limits">
                                    <Grid Margin="5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="Force courses to end by a specific time (e.g. PE -> 4 PM)" Foreground="Gray" FontSize="13" Margin="0,0,0,5"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                            <ComboBox x:Name="TimeRuleInput" Width="100" Height="25" 
                                                            IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                                                            KeyUp="CourseInput_KeyUp" ToolTip="Type to search Course Code (e.g. CS101)"/>
                                            <TextBlock Text="End by:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                                            <ComboBox x:Name="TimeRuleCombo" Width="90" Height="25" SelectedIndex="3">
                                                <ComboBoxItem Content="1:00 PM" Tag="13"/>
                                                <ComboBoxItem Content="2:00 PM" Tag="14"/>
                                                <ComboBoxItem Content="3:00 PM" Tag="15"/>
                                                <ComboBoxItem Content="4:00 PM" Tag="16"/>
                                                <ComboBoxItem Content="5:00 PM" Tag="17"/>
                                                <ComboBoxItem Content="6:00 PM" Tag="18"/>
                                            </ComboBox>
                                            <Button Content="Add" Width="50" Margin="10,0,0,0" Click="AddTimeRule_Click"/>
                                        </StackPanel>

                                        <ListBox x:Name="TimeRulesList" Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="1" Padding="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="transparent" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="12" Padding="8,3" Margin="0,0,5,5">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock Text="{Binding DisplayString}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                                            <Button Content="X" DockPanel.Dock="Right" Padding="1" Width="16" Height="16" Cursor="Hand"
                                                                    Background="Transparent" Foreground="#E74C3C" FontWeight="Bold" BorderThickness="0" 
                                                                    Click="RemoveTimeRule_Click" Tag="{Binding}"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="🚫 Exclusions">
                                    <Grid Margin="5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="Completely exclude these courses from the schedule (e.g. OJT)" Foreground="Gray" FontSize="13" Margin="0,0,0,5"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                            <ComboBox x:Name="ExclusionInput" Width="100" Height="25" 
                                                            IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                                                            KeyUp="CourseInput_KeyUp" ToolTip="Type to search Course Code (e.g. CS101)"/>
                                            <Button Content="Exclude Course" Width="100" Margin="10,0,0,0" Click="AddExclusion_Click"/>
                                        </StackPanel>

                                        <ListBox x:Name="ExclusionList" Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="1" Padding="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="transparent" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="12" Padding="8,3" Margin="0,0,5,5">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                                            <Button Content="X" DockPanel.Dock="Right" Padding="1" Width="16" Height="16" Cursor="Hand"
                                                                    Background="Transparent" Foreground="#E74C3C" FontWeight="Bold" BorderThickness="0" 
                                                                    Click="RemoveExclusion_Click" Tag="{Binding}"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </GroupBox>

                        <GroupBox Header="General Rules" Padding="10">
                            <StackPanel>
                                <CheckBox x:Name="LunchBreakCheck" Content="Enforce Lunch Break (12:00 PM - 1:00 PM)" 
                                          IsChecked="True" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="Max Calculation Time:" Margin="0,10,0,5"/>
                                <DockPanel>
                                    <TextBlock x:Name="TimeLimitLabel" Text="10 mins" DockPanel.Dock="Right" FontWeight="Bold" Width="50" TextAlignment="Right"/>
                                    <Slider x:Name="TimeLimitSlider" Minimum="1" Maximum="30" Value="10" 
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="TimeLimitSlider_ValueChanged"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            
            <TabItem Header="Patterns" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        
                        <GroupBox Header="Block Splitting Rules" Margin="0,0,0,15" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Automatically split 3-hour classes into two 1.5-hour sessions." 
                                           Foreground="Gray" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                
                                <CheckBox x:Name="BlockSplitCheck" Content="Enable Block Splitting" IsChecked="True" FontWeight="SemiBold"/>

                                <TextBlock Text="Exceptions (Keep these as single 3-hour blocks):" Margin="0,10,0,5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <ComboBox x:Name="SplitExceptionInput" Width="100" Height="25" 
                                            IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                                            KeyUp="CourseInput_KeyUp" ToolTip="Type to search (e.g. CS101 - Lec)"/>
                                    <Button Content="Add Exception" Width="100" Margin="10,0,0,0" Click="AddSplitException_Click"/>
                                </StackPanel>

                                <ListBox x:Name="SplitExceptionList" Height="100" BorderBrush="#EEEEEE" BorderThickness="1" Padding="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="transparent" BorderBrush="#7F8C8D" BorderThickness="1" CornerRadius="12" Padding="8,3" Margin="0,0,5,5">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                                    <Button Content="X" DockPanel.Dock="Right" Padding="1" Width="16" Height="16" Cursor="Hand"
                                                            Background="Transparent" Foreground="#E74C3C" FontWeight="Bold" BorderThickness="0" 
                                                            Click="RemoveSplitException_Click" Tag="{Binding}"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Day Spacing (Sibling Pattern)" Padding="10">
                            <StackPanel>
                                <TextBlock Text="How should split sessions be spaced? (e.g. Mon/Thu)" Foreground="Gray" FontSize="13" Margin="0,0,0,5"/>
                                
                                <ComboBox x:Name="SiblingPatternCombo" Height="30" SelectedIndex="0" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Strict (Mon/Thu, Tue/Fri, Wed/Sat)" Tag="Strict"/>
                                    <ComboBoxItem Content="Relaxed (At least 1 day gap)" Tag="Relaxed"/>
                                    <ComboBoxItem Content="None (Any two days)" Tag="None"/>
                                </ComboBox>

                                <TextBlock Text="• Strict: Best for uniform schedules." FontSize="13" Foreground="Gray"/>
                                <TextBlock Text="• Relaxed: Allows Mon/Wed, Tue/Thu. Easier to solve." FontSize="13" Foreground="Gray"/>
                                <TextBlock Text="• None: Allows Mon/Tue. Use only if generation fails." FontSize="13" Foreground="Gray"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <TabItem Header="Performance" FontSize="14">
                <StackPanel Margin="15">
                    <Border Background="#E8F6F3" BorderBrush="#1ABC9C" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Detected System Specs:" FontWeight="Bold" Foreground="#16A085"/>
                            <TextBlock x:Name="HardwareInfoTxt" Text="Scanning..." Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="CPU Usage Intensity:" FontWeight="SemiBold"/>
                    <Slider x:Name="PerformanceSlider" Minimum="1" Maximum="3" Value="2" 
                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,5"
                            ValueChanged="PerformanceSlider_ValueChanged"/>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Eco (Safe)" HorizontalAlignment="Left" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="Balanced" HorizontalAlignment="Center" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="Max Power" HorizontalAlignment="Right" FontSize="13" Foreground="Gray"/>
                    </Grid>

                    <TextBlock x:Name="PerformanceDescTxt" Text="Uses 50% of CPU cores." FontStyle="Italic" TextWrapping="Wrap" Foreground="#34495E" Margin="0,10,0,0"/>
                    <Border x:Name="LowRamWarning" Background="#FDEDEC" BorderBrush="#E74C3C" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,20,0,0" Visibility="Collapsed">
                        <TextBlock Text="⚠️ Warning: Your system has low RAM. 'Max Power' may cause crashes. 'Eco' is recommended." 
                                TextWrapping="Wrap" Foreground="#C0392B" FontSize="13"/>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save Settings" Width="120" Height="30" Click="Save_Click" Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>