<Window x:Class="UniversityScheduler.Views.AddRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Room" Height="550" Width="600" WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip" Icon="/UNIGAMIicon128.ico">
    <Border Padding="20" Background="#F7F9F9">
        <StackPanel>
            <TextBlock Text="Room Details" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Room Name:"/>
                    <TextBox x:Name="NameTxt" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Type:"/>
                    <ComboBox x:Name="TypeCombo" Height="30" SelectedIndex="0">
                        <ComboBoxItem Content="Classroom"/>
                        <ComboBoxItem Content="Laboratory"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Floor Lvl:"/>
                    <TextBox x:Name="FloorTxt" Height="30" Text="1"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Capacity:"/>
                    <TextBox x:Name="CapTxt" Height="30" Text="40"/>
                </StackPanel>
            </Grid>

            <Separator Margin="0,10"/>
            
            <TextBlock Text="Equipment Inventory (Qty)" FontWeight="Bold" Margin="0,0,0,10"/>
            <UniformGrid Columns="3" Rows="3">
                <StackPanel Margin="5">
                    <TextBlock Text="Chairs:"/>
                    <TextBox x:Name="ChairsTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Tables:"/>
                    <TextBox x:Name="TablesTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Computers:"/>
                    <TextBox x:Name="CompsTxt" Text="0"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Ceiling Fans:"/>
                    <TextBox x:Name="CeilFanTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Stand Fans:"/>
                    <TextBox x:Name="StandFanTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="AC Units:"/>
                    <TextBox x:Name="AcTxt" Text="0"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Whiteboards:"/>
                    <TextBox x:Name="WhiteboardTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Monitors:"/>
                    <TextBox x:Name="MonitorTxt" Text="0"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Projectors:"/>
                    <TextBox x:Name="ProjectorTxt" Text="0"/>
                </StackPanel>
            </UniformGrid>

            <Button Content="Save Room" Height="35" Style="{StaticResource PrimaryButton}" Margin="0,10,0,0" Click="Save_Click"/>
        </StackPanel>
    </Border>
</Window>