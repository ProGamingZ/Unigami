<Window x:Class="UniversityScheduler.Views.AddSectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add new Class" Height="400" Width="400" WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Icon="/UNIGAMIicon128.ico">
    <Border Padding="20" Background="#F7F9F9">
        <StackPanel>
            <TextBlock Text="Class Details" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Program:"/>
                <ComboBox x:Name="ProgramCombo" Height="30" IsEditable="True"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Year Level:"/>
                <ComboBox x:Name="YearCombo" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="1st Year" Tag="1"/>
                    <ComboBoxItem Content="2nd Year" Tag="2"/>
                    <ComboBoxItem Content="3rd Year" Tag="3"/>
                    <ComboBoxItem Content="4th Year" Tag="4"/>
                </ComboBox>
            </StackPanel>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Section Name (e.g., A):"/>
                    <TextBox x:Name="NameTxt" Height="30"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Student Count:"/>
                    <TextBox x:Name="CountTxt" Height="30" Text="40"/>
                </StackPanel>
            </Grid>

            <Button Content="Save Section" Style="{StaticResource PrimaryButton}" Height="35" Click="Save_Click"/>
        </StackPanel>
    </Border>
</Window>