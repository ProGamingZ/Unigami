<Window x:Class="UniversityScheduler.Views.DatabaseMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Migration Tool" Height="300" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True"
        Background="#F7F9F9" Icon="/UNIGAMIicon128.ico">

    <Border Padding="20">
        <StackPanel VerticalAlignment="Center">
            
            <TextBlock Text="Database Data Pump" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
            <TextBlock Text="Upgrading and migrating your old data..." Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <ProgressBar x:Name="MigrationProgress" Height="20" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,15"/>
            
            <TextBlock x:Name="StatusText" Text="Ready to begin." FontSize="14" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <Button x:Name="StartBtn" Content="Start Migration" Style="{StaticResource MasterSchedButtonStyle}"  Click="StartBtn_Click"/>
            <Button x:Name="RestartBtn" Content="Restart Application" Style="{StaticResource MasterSchedButtonStyle}" Visibility="Collapsed" Click="RestartBtn_Click"/>

        </StackPanel>
    </Border>
</Window>