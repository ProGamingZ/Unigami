<UserControl x:Class="UniversityScheduler.Views.CoursesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="600" d:DesignWidth="800"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1" BorderBrush="{StaticResource TextLightBrush}" BorderThickness="1" CornerRadius="4" Background="White" Height="35">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    <TextBox x:Name="SearchTxt" Grid.Column="1" BorderThickness="0" VerticalContentAlignment="Center" 
                             Padding="0,0,5,0" Background="Transparent" 
                             TextChanged="SearchTxt_TextChanged"
                             Tag="Search Code or Title..."/>
                </Grid>
            </Border>
        </Grid>

        <DataGrid x:Name="CoursesGrid" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  CanUserAddRows="False" 
                  BorderThickness="1" 
                  BorderBrush="{StaticResource TextLightBrush}"
                  HorizontalGridLinesBrush="{StaticResource TextLightBrush}"
                  VerticalGridLinesBrush="{StaticResource TextLightBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80" FontWeight="Bold"/>
                
                <DataGridTextColumn Header="Description" Binding="{Binding Name}" Width="270"/>
                <DataGridTextColumn Header="Units" Binding="{Binding Units}" Width="50"/>
                
                <DataGridTextColumn Header="Lec" Binding="{Binding LectureHours, StringFormat={}{0} Lec}" Width="60"/>
                <DataGridTextColumn Header="Lab" Binding="{Binding LabHours, StringFormat={}{0} Lab}" Width="60"/>
                
                <DataGridTextColumn Header="Prerequisites" Binding="{Binding PrerequisiteCodes}" Width="150" Foreground="{StaticResource DangerBrush}"/>
                
                <DataGridTextColumn Header="Programs" Binding="{Binding RecommendedPrograms}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Reset All" 
                    Style="{StaticResource DangerButton}" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="Reset_Click"/>

            <Button Content="Edit Course" 
                    Style="{StaticResource SecondaryButton}"
                    Width="140" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="Edit_Click"/>

            <Button Content="Remove Course" 
                    Style="{StaticResource DangerButton}" 
                    Width="140" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="Delete_Click"/>

            <Button Content="Manage Programs" 
                    Style="{StaticResource SecondaryButton}"
                    Width="140" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="ManagePrograms_Click"/>

            <Button Content="Add Course" 
                    Style="{StaticResource PrimaryButton}"
                    Width="140" 
                    Height="35" 
                    Click="Add_Click"/>

            
        </StackPanel>
    </Grid>
</UserControl>