<Window x:Class="UniversityScheduler.Views.ManageProgramsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Degree Programs" Height="400" Width="550" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F7F9F9" Icon="/UNIGAMIicon128.ico">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Column="0" Header="Active Programs">
            <ListBox x:Name="ProgramList" Margin="5" SelectionChanged="ProgramList_SelectionChanged" BorderBrush="#BDC3C7">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Code}" FontWeight="SemiBold" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <GroupBox Grid.Column="2" Header="Program Details">
            <StackPanel Margin="10">
                <TextBlock Text="Program Code (e.g. BSCS):" Foreground="Gray" FontSize="11"/>
                <TextBox x:Name="CodeTxt" Height="30" Margin="0,5,0,15" FontWeight="Bold"/>

                <TextBlock Text="Description (Optional):" Foreground="Gray" FontSize="11"/>
                <TextBox x:Name="DescTxt" Height="30" Margin="0,5,0,20"/>

                <Button Content="Add New Program" Height="35" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" Click="Add_Click"/>
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save Edits" Height="35" Style="{StaticResource SecondaryButton}" Click="Update_Click"/>
                    <Button Grid.Column="2" Content="Remove" Height="35" Style="{StaticResource DangerButton}" Click="Delete_Click"/>
                </Grid>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>