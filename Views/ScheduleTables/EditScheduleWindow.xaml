<Window x:Class="UniversityScheduler.Views.EditScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Edit Schedule" Height="800" Width="500" 
        Icon="pack://application:,,,/UNIGAMIicon128.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    
    <Border Padding="20" Background="#F7F9F9">
        <StackPanel>
            <TextBlock x:Name="TitleTxt" Text="Edit Class Schedule" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

            <GroupBox Header="Class Details" Margin="0,0,0,15" Padding="10">
               <Grid>
                  <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="Section:" VerticalAlignment="Center" Margin="0,0,10,10" Grid.Row="0" Grid.Column="0"/>
                  <ComboBox x:Name="SectionCombo" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,10" 
                              DisplayMemberPath="FullDisplayName" 
                              SelectedValuePath="Id"
                              SelectionChanged="SectionCombo_SelectionChanged"/>

                  <TextBlock Text="Course:" VerticalAlignment="Center" Margin="0,0,10,0" Grid.Row="1" Grid.Column="0"/>
                  <ComboBox x:Name="CourseCombo" Grid.Row="1" Grid.Column="1" Height="30" 
                              DisplayMemberPath="Code" 
                              SelectedValuePath="Id"
                              SelectionChanged="CourseCombo_SelectionChanged"/>
               </Grid>
            </GroupBox>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Day:" VerticalAlignment="Center" Margin="0,0,10,10" Grid.Row="0"/>
                <ComboBox x:Name="DayCombo" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,10" SelectionChanged="TimeFilter_Changed">
                    <ComboBoxItem Content="Mon" Tag="Mon"/>
                    <ComboBoxItem Content="Tue" Tag="Tue"/>
                    <ComboBoxItem Content="Wed" Tag="Wed"/>
                    <ComboBoxItem Content="Thu" Tag="Thu"/>
                    <ComboBoxItem Content="Fri" Tag="Fri"/>
                    <ComboBoxItem Content="Sat" Tag="Sat"/>
                    <ComboBoxItem Content="Sun" Tag="Sun"/>
                </ComboBox>

                <TextBlock Text="Time:" VerticalAlignment="Center" Margin="0,0,10,10" Grid.Row="1"/>
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="StartTimeCombo" Height="30" SelectionChanged="TimeFilter_Changed"/>
                    <TextBlock Text="to" Grid.Column="1" VerticalAlignment="Center" Margin="5,0"/>
                    <ComboBox x:Name="EndTimeCombo" Grid.Column="2" Height="30" SelectionChanged="TimeFilter_Changed"/>
                </Grid>
cls
                <TextBlock Text="Room:" VerticalAlignment="Center" Margin="0,0,10,10" Grid.Row="2"/>
                <ComboBox x:Name="RoomCombo" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Instructor:" VerticalAlignment="Top" Margin="0,0,10,0" Grid.Row="3"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                    <ComboBox x:Name="InstructorCombo" 
                            Height="30" 
                            DisplayMemberPath="FullName" 
                            SelectedValuePath="Id"
                            SelectionChanged="InstructorCombo_SelectionChanged"/>

                    <Border Background="#FFF8E1" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="4" Margin="0,5,0,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="📅 Schedule Preferences:" FontWeight="SemiBold" FontSize="14" Foreground="#B7950B" Margin="0,0,0,2"/>
                            <TextBlock x:Name="PreferenceTxt" 
                                    Text="Select an instructor..." 
                                    FontSize="13" 
                                    Foreground="#555" 
                                    TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Delete Class" Background="#C0392B" Foreground="White" Width="100" Height="35" Margin="0,0,10,0" Click="Delete_Click"/>
                <Button Content="Save Changes" Background="#27AE60" Foreground="White" Width="100" Height="35" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>